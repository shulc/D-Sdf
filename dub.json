{
    "name": "d-sdf",
    "description": "D bindings for a thin C shim around sxyu/sdf — mesh to signed-distance field (SDF). Static linking via bundled Eigen 3.4.0 submodule.",
    "license": "BSD-2-Clause",
    "authors": ["Alexander Shagarov"],

    "sourcePaths": ["source"],
    "importPaths": ["source"],

    "preBuildCommands-posix": [
        "cd \"$PACKAGE_DIR\" && git submodule update --init --recursive --quiet",
        "cmake -S \"$PACKAGE_DIR\" -B \"$PACKAGE_DIR/build\" -DCMAKE_BUILD_TYPE=Release",
        "cmake --build \"$PACKAGE_DIR/build\" -j --target sdf_c"
    ],
    "lflags-posix": ["-L$PACKAGE_DIR/build"],
    "libs-linux": ["sdf_c", "stdc++", "pthread", "m"],
    "libs-osx":   ["sdf_c", "c++", "m"],

    "preBuildCommands-windows": [
        "git -C \"$PACKAGE_DIR\" submodule update --init --recursive",
        "cmake -S \"$PACKAGE_DIR\" -B \"$PACKAGE_DIR/build\"",
        "cmake --build \"$PACKAGE_DIR/build\" --config Release --target sdf_c"
    ],
    "lflags-windows": ["$PACKAGE_DIR/build/Release/sdf_c.lib"],
    "dflags-windows": ["-mscrtlib=msvcrt"],

    "configurations": [
        {
            "name": "library",
            "targetType": "staticLibrary"
        },
        {
            "name": "sdf_cube",
            "targetType": "executable",
            "targetName": "sdf_cube",
            "mainSourceFile": "examples/sdf_cube.d"
        }
    ]
}
